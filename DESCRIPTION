Package: tidySpatialWorkshop
Title: Workshop Materials for Tidy Spatial Analysis
Version: 0.19.0
Authors@R: c(
    person("Stefano", "Mangiola", email = "mangiola.s@wehi.edu.au", role = c("aut", "cre"),
